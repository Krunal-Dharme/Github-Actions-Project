# =============================================================================
# Pipeline Health Monitor — environment variables
# Copy to .env for local runs. Never commit .env with real secrets.
# =============================================================================

# --- Required: GitHub ---
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
# Alias: GITHUB_REPO=owner/repo

# Version 1: explicit workflow run invocation (CLI or workflow env)
WORKFLOW_RUN_ID=
WORKFLOW_RUN_STATUS=failure
GITHUB_EVENT_PATH=./sample-event.json
GITHUB_API_URL=https://api.github.com

# --- Required: OpenRouter (sole LLM provider) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Alias: MODEL_NAME=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TEMPERATURE=0.0
OPENROUTER_REFERER=https://github.com/your-org/your-repo
USE_LANGCHAIN_AGENT=false
AGENT_MAX_ITERATIONS=3

# --- Optional: Postgres (investigation history on pipeline-demo VM) ---
POSTGRES_ENABLED=false
# Aliases: ENABLE_DB=false
#
# Option A — single connection string (recommended for GitHub Actions secrets):
# DATABASE_URL=postgresql://pipeline_user:YOUR_PASSWORD@YOUR_VM_PUBLIC_IP:5432/pipeline_history?sslmode=require
# Note: URL-encode special characters in password (@ → %40, etc.)
POSTGRES_DSN=
DATABASE_URL=
#
# Option B — individual fields (local .env on pipeline-demo or split GitHub secrets):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_history
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer
POSTGRES_AUDIT_ENABLED=true

# --- Optional: Email (SMTP notifications) ---
EMAIL_ENABLED=false
# Alias: ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=
# Alias: EMAIL_SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Alias: EMAIL_SMTP_PORT=587
SMTP_USER=
# Alias: EMAIL_USERNAME=
SMTP_PASSWORD=
# Alias: EMAIL_PASSWORD=
SMTP_FROM=
# Alias: EMAIL_FROM=pipeline-monitor@example.com
EMAIL_RECIPIENTS=
# Aliases: EMAIL_TO=team@example.com
NOTIFY_ON_SUCCESS=false

# --- Rate limits & cost controls ---
MAX_INVESTIGATIONS_PER_DAY=50
MAX_LLM_CALLS_PER_RUN=1
MAX_LOG_CHARS=80000
MAX_COMMITS_TO_ANALYZE=10
COMMIT_LOOKBACK_HOURS=24
DEDUPE_WINDOW_HOURS=24

# --- Issue management ---
ISSUE_LABEL=pipeline-failure
ISSUE_UPDATE_EXISTING=true
# When true, Python skips issue creation; GitHub Actions workflow posts the issue
SKIP_GITHUB_ISSUE_PUBLISH=false

# --- Audit logging ---
AUDIT_LOG_DIR=.agent_logs
AUDIT_LOG_LEVEL=INFO
